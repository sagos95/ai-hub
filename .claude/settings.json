{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-plugin-version.sh"
          }
        ]
      }
    ]
  },
  "plugins": [
    "./integrations/kaiten",
    "./integrations/spike",
    "./integrations/reverse-product-analysis",
    "./integrations/test-factory",
    "./integrations/discovery",
    "./integrations/development",
    "./integrations/buildin",
    "./integrations/holst",
    "./integrations/hub-meta"
  ]
}
