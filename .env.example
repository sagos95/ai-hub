# AI Hub Environment Configuration
# Copy this file to .env and fill in your values
# Or run /ai-hub:setup for guided configuration

# =============================================================================
# Company Config (set via /ai-hub:setup or manually)
# These are non-secret values shared across your organization.
# =============================================================================

# Kaiten domain (without https:// and trailing slash)
KAITEN_DOMAIN=your-company.kaiten.io

# Time (Mattermost) base URL
TIME_BASE_URL=https://your-company.time-messenger.ru

# Buildin workspace space ID (UUID)
BUILDIN_SPACE_ID=your-space-uuid-here

# Databricks Genie settings (optional)
# GENIE_HOST=https://your-region.azuredatabricks.net
# GENIE_SPACE_ID=your-genie-space-id

# =============================================================================
# Personal Tokens (each user sets their own)
# =============================================================================

# Kaiten API token
# Get from: Kaiten -> Profile Settings -> API/Integrations
KAITEN_TOKEN=your_kaiten_api_token

# Databricks Genie token (optional)
# GENIE_TOKEN=your_databricks_token

# --- Auto-managed tokens (set by login skills, no manual editing needed) ---

# Buildin UI token (set by /ai-hub:buildin-login)
# BUILDIN_UI_TOKEN=

# Time personal token (set by /ai-hub:time-login)
# TIME_TOKEN=

# Time bot token (optional, for automated posts)
# TIME_BOT_TOKEN=
